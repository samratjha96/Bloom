// Flatten COPY to dotted keys so the client can swap text by [data-i18n] attribute
function flatten(obj, prefix = '', out = {}) {
  for (const [k, v] of Object.entries(obj)) {
    const key = prefix ? `${prefix}.${k}` : k;
    if (Array.isArray(v)) {
      v.forEach((item, i) => {
        if (item && typeof item === 'object') flatten(item, `${key}.${i}`, out);
        else out[`${key}.${i}`] = item;
      });
    } else if (v && typeof v === 'object') {
      flatten(v, key, out);
    } else {
      out[key] = v;
    }
  }
  return out;
}
const FLAT = { en: flatten(COPY.en), zh: flatten(COPY.zh) };
const en = COPY.en; // initial render is English (good for SEO / no-JS)

// ── Twin normal distributions, +2σ apart — computed at build time ──
const W = 560, H = 320, baseY = 250, x0 = 40, x1 = 520, sigma = 48, amp = 168;
const meanA = 196;
const meanB = meanA + 2 * sigma; // 292
const peak = baseY - amp;        // 82
function curve(cx) {
  let d = '';
  for (let x = x0; x <= x1; x += 3) {
    const y = baseY - amp * Math.exp(-((x - cx) ** 2) / (2 * sigma * sigma));
    d += `${d ? 'L' : 'M'}${x.toFixed(1)},${y.toFixed(1)} `;
  }
  return d.trim();
}
const area = (cx) => `${curve(cx)} L${x1},${baseY} L${x0},${baseY} Z`;
const greyCurve = curve(meanA), greyArea = area(meanA);
const emCurve = curve(meanB), emArea = area(meanB);

const CODE = `git clone ${GITHUB}.git
cd Bloom
cp .env.example .env          # add your LLM_API_KEY

# backend
cd backend && uv sync && uv run uvicorn app.main:app --reload --port 8000

# frontend (new terminal)
cd frontend && npm install && npm run dev`;

const dotGrid =
  'background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.05) 1px, transparent 0); background-size: 26px 26px;';
