  <script>
    const data = JSON.parse(document.getElementById('i18n-data').textContent);

    function apply(lang) {
      document.documentElement.setAttribute('data-lang', lang);
      document.documentElement.lang = lang === 'zh' ? 'zh-CN' : 'en';
      document.querySelectorAll('[data-i18n]').forEach((el) => {
        const v = data[lang][el.getAttribute('data-i18n')];
        if (v != null) el.textContent = v;
      });
      document.querySelectorAll('[data-i18n-label]').forEach((el) => {
        el.textContent = lang === 'en' ? '中文' : 'EN';
      });
    }

    let current = 'en';
    try { current = localStorage.getItem('bloom_lang') === 'zh' ? 'zh' : 'en'; } catch (e) {}
    if (current === 'zh') apply('zh');
    else document.querySelectorAll('[data-i18n-label]').forEach((el) => (el.textContent = '中文'));

    document.querySelectorAll('[data-lang-toggle]').forEach((btn) =>
      btn.addEventListener('click', () => {
        current = document.documentElement.getAttribute('data-lang') === 'en' ? 'zh' : 'en';
        try { localStorage.setItem('bloom_lang', current); } catch (e) {}
        apply(current);
      })
    );

    // Reveal-on-scroll — reveal when in view OR once scrolled past, so fast flings never strand content
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const els = document.querySelectorAll('.reveal');
    if (reduce) {
      els.forEach((el) => el.classList.add('reveal-in'));
    } else {
      const obs = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting || e.boundingClientRect.top < 0) {
              e.target.classList.add('reveal-in');
              obs.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );
      els.forEach((el) => obs.observe(el));
    }

    // Copy quick-start command
    const copyBtn = document.getElementById('copy-btn');
    copyBtn?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(document.getElementById('code-block').textContent);
        copyBtn.textContent = '✓ ' + data[current]['start.copied'];
        setTimeout(() => { copyBtn.textContent = data[current]['start.copy']; }, 1800);
      } catch (e) {}
    });
  </script>
